# 复制为 .env 后填写（勿提交含密码的 .env 到 Git）
# cp .env.example .env
#
# 注意：注释必须以 # 开头；不要写「数据库=xxx」这类无 # 的中文行

FLINK_WEB_PORT=8089

# ========== Flink 资源 ==========
# 40核64G+: FLINK_TASK_SLOTS=40 FLINK_TM_MEMORY=57344m FLINK_PARALLELISM_BULK=40
# 20核:     FLINK_TASK_SLOTS=20 FLINK_PARALLELISM_BULK=20
FLINK_TASK_SLOTS=40
FLINK_TM_MEMORY=57344m
# 全量 bulk 读 FLINK_PARALLELISM_BULK；FLINK_PARALLELISM 给 incr 时可设 1
FLINK_PARALLELISM=40
FLINK_PARALLELISM_BULK=40
FLINK_PARALLELISM_INCR=4
# user_info 增量/全量专用并行（Lookup + VT UDF 较重；默认=2× INCR，可显式固定如 8/12）
# FLINK_PARALLELISM_USER_INFO=8
# FLINK_PARALLELISM_USER_INFO_INCR=8
# FLINK_PARALLELISM_USER_INFO_BULK=20
# user_info 脏队列 Flink 侧合并窗口（秒）：同 user 多条 binlog mini-batch
USER_INFO_DIRTY_COALESCE_SEC=5
# deploy-source-ddl：CREATE VIEW 等 MDL 锁最长等待（秒）
SOURCE_DDL_LOCK_WAIT_TIMEOUT=120
SOURCE_DDL_KILL_MIN_TIME=3
# 增量启动默认跳过 Lookup 视图重建（1=跳过已存在视图，避免与 Flink JDBC Lookup 抢锁）
DEPLOY_SOURCE_DDL_SKIP_IF_OK=1
# VT 表全量阶段 2（user/user_info/bankcard/application 运行时 /v2t）并行度，勿过大
FLINK_PARALLELISM_VT_MISS=2
FLINK_MINI_BATCH_SIZE=10000
FLINK_SINK_BUFFER_ROWS=50000
FLINK_CDC_CHUNK_SIZE=500000
FLINK_CDC_FETCH_SIZE=50000
# 增量多 CDC Job checkpoint（默认 300s 间隔 / 1800s 超时）
FLINK_CHECKPOINT_INTERVAL=300s
FLINK_CHECKPOINT_TIMEOUT=1800s
# user_info 脏队列 CDC（单源、无 incremental snapshot）须单值，勿写 5401-5404
CDC_SERVER_ID_UI_DIRTY=5401

# 完整迁移: ./scripts/sync-migrate-auto.sh
# 从零重跑: ./scripts/full-rerun.sh
# 目标库已有数据时全量监控（见 config/sync-jobs.conf 各表计数 SQL）：
# - user/user_info/.../loan：目标 SQL 只数「本迁移切片」（user_id/group_user_id > USER_ID_OFFSET 或 ng0%），
#   监控口径 absolute：期望 目标≈宽表（UPSERT 重叠不会让全表总数虚增）
# - id_mapping：仍用 baseline_delta（基线+宽表≈目标总数）
SYNC_TARGET_BASELINE_AUTO=1
# SYNC_TARGET_BASELINE=1234567   # 手动指定基线（仅 baseline_delta 口径）
# SYNC_MONITOR_COUNT_MODE=auto    # auto|absolute|baseline_delta
# SYNC_REQUIRE_EXACT_COUNT=1
# SYNC_COUNT_MAX_DEFICIT=10
# SYNC_COUNT_MAX_SURPLUS=100
# 4C8G 小机: FLINK_TASK_SLOTS=4 FLINK_TM_MEMORY=4096m FLINK_PARALLELISM=4
# 改 slot 后: docker compose up -d --force-recreate taskmanager

# ========== 源库（API 现库 nigeria_backend）==========
SOURCE_MYSQL_HOST=47.xxx.xxx.xxx
SOURCE_MYSQL_PORT=3306
SOURCE_MYSQL_USER=flink_cdc
SOURCE_MYSQL_PASSWORD=change_me
SOURCE_MYSQL_DATABASE=nigeria_backend
# 源库高权限账号（可选兜底）：仅当 flink_cdc 无 CREATE ROUTINE/TRIGGER 时使用
# flink_cdc 若已能建存储过程+TRIGGER，无需配置下面两行
# SOURCE_MYSQL_ROOT_USER=root
# SOURCE_MYSQL_ROOT_PASSWORD=change_me

# ========== 目标库（中台 Target.sql）==========
TARGET_MYSQL_HOST=47.xxx.xxx.xxx
TARGET_MYSQL_PORT=3306
TARGET_MYSQL_USER=platform_writer
TARGET_MYSQL_PASSWORD=change_me
TARGET_MYSQL_DATABASE=platform_db

USER_ID_OFFSET=100000000

# VT 服务（scripts/vt-preload.sh 批量 /v2t；Flink 生产 Job 不调 VT）
VT_BASE_URL=http://101.47.27.225
# 预加载 VT 字典（scripts/vt-preload.sh）
# fast=认领+VT+异步UPSERT（目标 20万/分钟，需 init_all）
VT_PRELOAD_MODE=fast
VT_PRELOAD_WORKERS=4
VT_PRELOAD_HTTP_BATCH=50000
VT_PRELOAD_BATCH_SIZE=0
VT_PRELOAD_ASYNC_WRITE=1
VT_PRELOAD_WRITE_WORKERS=2
# update_id=SELECT id 后 UPDATE（默认，无需 DELETE）；delete_insert=需 DELETE 权限
# update_id 慢；delete_insert 需 DELETE 权限且须关异步写
VT_PRELOAD_WRITE_MODE=upsert
# VT_PRELOAD_WRITE_MODE=delete_insert
# VT_PRELOAD_ASYNC_WRITE=0
# 等待 VT/入库期间心跳日志间隔（秒），0=关闭
VT_PRELOAD_HEARTBEAT_SEC=30
# 拉满并发（20 核机器）：workers=20 claim=1000000 http=50000 → 每轮 20 路并行各 5 万
# VT_PRELOAD_BATCH_SIZE=1000000
# VT_PRELOAD_WORKERS=20
# VT_PRELOAD_HTTP_BATCH=50000

# ========== 雪花 ID（user_bankcard 全量发号，TaskManager 读取）==========
# 与中台 Java 服务对齐 epoch/worker 段；全量 UPSERT 会覆盖目标已有 id（可接受全新发号）
# SNOWFLAKE_EPOCH_MS=1288834974657
# SNOWFLAKE_DATACENTER_ID=0
# SNOWFLAKE_WORKER_ID_BITS=5
# SNOWFLAKE_DATACENTER_ID_BITS=5
# SNOWFLAKE_SEQUENCE_BITS=12
# workerId = SNOWFLAKE_WORKER_ID_BASE + subtaskIndex（默认 32 起，避开线上 0~31）
# SNOWFLAKE_WORKER_ID_BASE=32
# 或固定单 worker（多 TM 实例时各自设不同值）：
# SNOWFLAKE_WORKER_ID=33
# 改后: docker compose up -d --force-recreate taskmanager
