# 复制为 .env 后填写（勿提交含密码的 .env 到 Git）
# cp .env.example .env
#
# 注意：注释必须以 # 开头；不要写「数据库=xxx」这类无 # 的中文行

FLINK_WEB_PORT=8089

# ========== Flink 资源 ==========
# 40核64G+: FLINK_TASK_SLOTS=40 FLINK_TM_MEMORY=57344m FLINK_PARALLELISM_BULK=40
# 20核:     FLINK_TASK_SLOTS=20 FLINK_PARALLELISM_BULK=20
FLINK_TASK_SLOTS=40
FLINK_TM_MEMORY=57344m
# 全量 bulk 读 FLINK_PARALLELISM_BULK；FLINK_PARALLELISM 给 incr 时可设 1
FLINK_PARALLELISM=40
FLINK_PARALLELISM_BULK=40
FLINK_PARALLELISM_INCR=1
# VT 表全量阶段 2（user/user_info/bankcard/application 运行时 /v2t）并行度，勿过大
FLINK_PARALLELISM_VT_MISS=2
FLINK_MINI_BATCH_SIZE=10000
FLINK_SINK_BUFFER_ROWS=50000
FLINK_CDC_CHUNK_SIZE=500000
FLINK_CDC_FETCH_SIZE=50000

# 一键全自动（建宽表+全量+增量，锁定 bulk-start-ms 补 binlog）:
#   ./scripts/sync-pipeline-auto.sh
# 勿先手工建宽表再另跑同步（会丢中间 binlog）；必须同一脚本内完成。
# 4C8G 小机改: FLINK_TASK_SLOTS=4 FLINK_TM_MEMORY=4096m FLINK_PARALLELISM=4
# 改 slot 后须重建 TM: FLINK_TASK_SLOTS=40 docker compose up -d --force-recreate taskmanager
# 老库一次性迁移: bash lm/scripts/run-ng-migration-bulk.sh
# 索引优化版试跑（LIMIT 20）: bash lm/scripts/run-ng-migration-bulk-opt.sh
# 优化版 user 试跑: LM_MIGRATION_LIMIT=20 bash lm/scripts/run-user-lm-bulk-opt.sh
# 优化版 user_info 试跑: LM_MIGRATION_LIMIT=20 bash lm/scripts/run-ng-user-info-opt.sh
# user_info CDC+Lookup（无库内 VIEW，推荐）: LM_MIGRATION_LIMIT=20 bash lm/scripts/run-ng-user-info-cdc-lookup.sh
# user_info Flink Join 减轻（MySQL VIEW）: LM_MIGRATION_LIMIT=20 bash lm/scripts/run-ng-user-info-opt-join.sh
# user_info Flink Join 分区读（全量大表）: FLINK_PARALLELISM=8 bash lm/scripts/run-ng-user-info-opt-partition.sh
# 优化版 application 试跑: LM_MIGRATION_LIMIT=20 bash lm/scripts/run-ng-application-opt.sh
# MySQL 对照校验: LM_MIGRATION_LIMIT=20 bash lm/scripts/run-lm-verify-mysql.sh application
# id_add_user 宽表: bash lm/scripts/run-id-add-user-bulk.sh
# 老库 user 表: bash lm/scripts/run-user-lm-bulk.sh
# user_info 试跑 100 条: LM_PICK_N=100 bash lm/scripts/run-ng-user-info-gpt-latest100.sh
# user_info 试跑（非 GPT JSON）: LM_PICK_N=100 bash lm/scripts/run-ng-user-info-latest100.sh
# user_info 纯 MySQL（无 Flink，推荐）: LM_PICK_N=20 bash lm/scripts/run-ng-user-info-mysql-only.sh
# user_info 纯 MySQL（两库隔离，mysqldump 中转）: LM_PICK_N=20 bash lm/scripts/run-ng-user-info-mysql-dump.sh

# ========== 源库（API 现库 nigeria_backend）==========
SOURCE_MYSQL_HOST=47.xxx.xxx.xxx
SOURCE_MYSQL_PORT=3306
SOURCE_MYSQL_USER=flink_cdc
SOURCE_MYSQL_PASSWORD=change_me
SOURCE_MYSQL_DATABASE=nigeria_backend

# ========== 老库 ng_loan_market（仅 03_sync_user_lm_bulk 一次性 Job，不改 SOURCE_* incr）==========
# 密码含 $ ^ 等特殊字符时请用单引号，勿用双引号（避免 shell 展开）:
# LM_MYSQL_PASSWORD='your-pass'
LM_MYSQL_HOST=
LM_MYSQL_PORT=17033
LM_MYSQL_USER=root
LM_MYSQL_PASSWORD=change_me
LM_MYSQL_DATABASE=ng_loan_market
# 老库 core（默认同 host/账号，仅库名不同）
LM_CORE_MYSQL_HOST=
LM_CORE_MYSQL_PORT=17033
LM_CORE_MYSQL_USER=
LM_CORE_MYSQL_PASSWORD=
LM_CORE_MYSQL_DATABASE=ng_loan_core
# 老库 Batch 试跑条数；全量 2147483647
LM_MIGRATION_LIMIT=2147483647
# JDBC 分区读上界（user/device 等大表 id 最大值，按老库 MAX(id) 调整）
# LM_MIGRATION_ID_UPPER=500000000
# CDC 多表快照 server-id 基址（每表占 10，避免 binlog 冲突）
# LM_CDC_SERVER_ID_BASE=5700
# id_add_user 宽表试跑: LM_MIGRATION_LIMIT=0 且脚本内 LIMIT 逻辑见 run-id-add-user-bulk.sh
# LM_ID_ADD_USER_MAX_PARALLEL=16
# 老库全量监控打印间隔（秒）
LM_SYNC_POLL_SEC=2

# ========== 目标库（中台 Target.sql）==========
TARGET_MYSQL_HOST=47.xxx.xxx.xxx
TARGET_MYSQL_PORT=3306
TARGET_MYSQL_USER=platform_writer
TARGET_MYSQL_PASSWORD=change_me
TARGET_MYSQL_DATABASE=platform_db

USER_ID_OFFSET=100000000

# VT 服务（scripts/vt-preload.sh 批量 /v2t；Flink 生产 Job 不调 VT）
VT_BASE_URL=http://101.47.27.225
# 预加载 VT 字典（scripts/vt-preload.sh）
# fast=认领+VT+异步UPSERT（目标 20万/分钟，需 init_all）
VT_PRELOAD_MODE=fast
VT_PRELOAD_WORKERS=4
VT_PRELOAD_HTTP_BATCH=50000
VT_PRELOAD_BATCH_SIZE=0
VT_PRELOAD_ASYNC_WRITE=1
VT_PRELOAD_WRITE_WORKERS=2
# update_id=SELECT id 后 UPDATE（默认，无需 DELETE）；delete_insert=需 DELETE 权限
VT_PRELOAD_WRITE_MODE=update_id
# 等待 VT/入库期间心跳日志间隔（秒），0=关闭
VT_PRELOAD_HEARTBEAT_SEC=30
# 拉满并发（20 核机器）：workers=20 claim=1000000 http=50000 → 每轮 20 路并行各 5 万
# VT_PRELOAD_BATCH_SIZE=1000000
# VT_PRELOAD_WORKERS=20
# VT_PRELOAD_HTTP_BATCH=50000
