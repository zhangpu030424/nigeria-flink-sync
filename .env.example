# 复制为 .env 后填写（勿提交含密码的 .env 到 Git）
# cp .env.example .env
#
# 注意：注释必须以 # 开头；不要写「数据库=xxx」这类无 # 的中文行

FLINK_WEB_PORT=8089

# ========== Flink 资源（32核64G 机器：30 slot 给 TM，留 2 核给 JM/系统）==========
FLINK_TASK_SLOTS=30
FLINK_TM_MEMORY=51200m
FLINK_PARALLELISM=30
FLINK_PARALLELISM_BULK=30
FLINK_PARALLELISM_INCR=1
FLINK_MINI_BATCH_SIZE=10000
FLINK_SINK_BUFFER_ROWS=50000
FLINK_CDC_CHUNK_SIZE=500000
FLINK_CDC_FETCH_SIZE=50000

# 4C8G 小机改: FLINK_TASK_SLOTS=4 FLINK_TM_MEMORY=4096m FLINK_PARALLELISM=4
# 全量独占 30 核: bash scripts/run-ng-user-info-bulk-max.sh
# 列表页 Tasks=4 是算子个数；真并行=Job详情 Parallelism（目标 30）
# 老库慢 VIEW 先落地: bash scripts/refresh-lm-user-info-staging.sh
# 与 incr 同跑则 BULK 会被 slot 公式自动压低

# ========== 源库（API 现库 nigeria_backend）==========
SOURCE_MYSQL_HOST=47.xxx.xxx.xxx
SOURCE_MYSQL_PORT=3306
SOURCE_MYSQL_USER=flink_cdc
SOURCE_MYSQL_PASSWORD=change_me
SOURCE_MYSQL_DATABASE=nigeria_backend

# ========== 老库 ng_loan_market（仅 03_sync_user_lm_bulk 一次性 Job，不改 SOURCE_* incr）==========
# 密码含 $ ^ 等特殊字符时请用单引号，勿用双引号（避免 shell 展开）:
# LM_MYSQL_PASSWORD='your-pass'
LM_MYSQL_HOST=
LM_MYSQL_PORT=17033
LM_MYSQL_USER=root
LM_MYSQL_PASSWORD=change_me
LM_MYSQL_DATABASE=ng_loan_market
# 老库 core（默认同 host/账号，仅库名不同）
LM_CORE_MYSQL_HOST=
LM_CORE_MYSQL_PORT=17033
LM_CORE_MYSQL_USER=
LM_CORE_MYSQL_PASSWORD=
LM_CORE_MYSQL_DATABASE=ng_loan_core
# ng_migration / user_info 试跑 20 条；全量 2147483647（勿用于 SortLimit，会 OOM）
LM_MIGRATION_LIMIT=2147483647
# id_add_user 宽表同步（05_sync_id_add_user_bulk）：默认 0=全量不加 LIMIT；试跑设 20
# LM_MIGRATION_LIMIT=0
# 两千万全量默认 16 并行（需 VIEW 含 user_id_part + FLINK_TASK_SLOTS>=16）
# LM_ID_ADD_USER_MAX_PARALLEL=16
# user_info 多表 JSON（04_sync_ng_user_info_bulk）32C64G 默认 30 路 JDBC
# LM_USER_INFO_MAX_PARALLEL=30
# SYNC_SLOT_BUFFER=0            # user_info 脚本默认 0，尽量吃满 30 slot
# SYNC_BULK_IGNORE_SLOT_CAP=1   # slot 不足时仍提交 30 并行（排队）
# SKIP_LM_VIEW_CREATE=1
# LM_SKIP_VIEW_PROBE=1
# FLINK_PARALLELISM_BULK=16
# FLINK_CDC_FETCH_SIZE=50000
# FLINK_SINK_BUFFER_ROWS=50000
# 老库 user 全量监控打印间隔（秒）
LM_SYNC_POLL_SEC=2

# ========== 目标库（中台 Target.sql）==========
TARGET_MYSQL_HOST=47.xxx.xxx.xxx
TARGET_MYSQL_PORT=3306
TARGET_MYSQL_USER=platform_writer
TARGET_MYSQL_PASSWORD=change_me
TARGET_MYSQL_DATABASE=platform_db

USER_ID_OFFSET=100000000

# VT 服务（scripts/vt-preload.sh 批量 /v2t；Flink 生产 Job 不调 VT）
VT_BASE_URL=http://101.47.27.225
# 预加载 VT 字典（scripts/vt-preload.sh）
# fast=认领+VT+异步UPSERT（目标 20万/分钟，需 init_all）
VT_PRELOAD_MODE=fast
VT_PRELOAD_WORKERS=4
VT_PRELOAD_HTTP_BATCH=50000
VT_PRELOAD_BATCH_SIZE=0
VT_PRELOAD_ASYNC_WRITE=1
VT_PRELOAD_WRITE_WORKERS=2
# update_id=SELECT id 后 UPDATE（默认，无需 DELETE）；delete_insert=需 DELETE 权限
VT_PRELOAD_WRITE_MODE=update_id
# 等待 VT/入库期间心跳日志间隔（秒），0=关闭
VT_PRELOAD_HEARTBEAT_SEC=30
# 拉满并发（20 核机器）：workers=20 claim=1000000 http=50000 → 每轮 20 路并行各 5 万
# VT_PRELOAD_BATCH_SIZE=1000000
# VT_PRELOAD_WORKERS=20
# VT_PRELOAD_HTTP_BATCH=50000
